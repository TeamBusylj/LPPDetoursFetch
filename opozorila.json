      "contentHtml": "\n\n                            <div class=\"content--wrapper\">\n\n                                \n\n                                <div class=\"content--top\">\n                                   \n                                  \n  <div class=\"field field-name-body field-type-text-with-summary field-label-hidden\">\n    <p data-end=\"101\" data-start=\"82\">Spoštovani potniki,</p>\n\n<p data-end=\"189\" data-start=\"103\">zaradi popolne prometne zapore na delu Škofjeloške ceste v naselju Vaše bo linija 15&nbsp;<strong data-end=\"251\" data-start=\"191\" style=\"font-size: 13.008px;\">od srede, 18. 3. 2026, </strong><span style=\"font-size: 13.008px;\">do zaključka gradbenih del,&nbsp;</span><span style=\"font-size: 13.008px;\">obratovala po spremenjeni trasi.</span></p>\n\n<p data-end=\"399\" data-start=\"325\">&nbsp;</p>\n\n<p data-end=\"399\" data-start=\"325\">V času popolne prometne zapore bo linija 15 preusmerjena na obvozno traso:</p>\n\n<ul data-end=\"581\" data-start=\"400\"><li data-end=\"445\" data-section-id=\"1lym9j8\" data-start=\"400\">\n\t\t<p data-end=\"445\" data-start=\"402\">po redni trasi do postajališča Vaše Helios, nato povratek do postajališča Medvoška a.p.,</p>\n\t</li>\n\t<li data-end=\"548\" data-section-id=\"umeprh\" data-start=\"493\">\n\t\t<p data-end=\"548\" data-start=\"495\">po obvozni trasi: Cesta komandanta Staneta, Goričane in nato naprej po redni trasi.</p>\n\t</li>\n</ul><p data-end=\"616\" data-start=\"583\">Enako velja tudi v obratni smeri.</p>\n\n<p data-end=\"653\" data-is-last-node=\"\" data-is-only-node=\"\" data-start=\"618\"><img alt=\"\" src=\"https://raw.githubusercontent.com/TeamBusylj/LPPDetoursFetch/main/slike/685f728b131ca0a0202b2dc0d6ed1a66.png\"></p>\n\n<p data-end=\"653\" data-is-last-node=\"\" data-is-only-node=\"\" data-start=\"618\">&nbsp;</p>\n\n<p data-end=\"653\" data-is-last-node=\"\" data-is-only-node=\"\" data-start=\"618\">Zahvaljujemo se vam za razumevanje.</p>\n  </div>\n    \n                                    \n                                </div>\n                                \n                                <div class=\"content--bottom\">\n                                \n                                \n                                </div>\n\n                               \n                                \n                                <div id=\"content__share\">\n                                    \n                                    \n                                    \n                                </div>\n\n                            </div>\n\n                        "
